{
  "name": "clankercraft",
  "version": "2.0.4",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "minecraft-mcp-server": "dist/main.js"
  },
  "ava": {
    "extensions": [
      "ts"
    ],
    "nodeArguments": [
      "--import=tsx"
    ]
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "start": "node dist/main.js",
    "test": "ava",
    "lint": "eslint \"{src,tests}/**/*.ts\"",
    "lint:fix": "eslint \"{src,tests}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "canvas": "^3.2.3",
    "minecraft-data": "^3.109.0",
    "mineflayer": "^4.37.0",
    "mineflayer-pathfinder": "^2.4.5",
    "prismarine-provider-anvil": "^2.13.0",
    "prismarine-viewer": "^1.33.0",
    "vec3": "^0.2.0",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ava/typescript": "^6.0.0",
    "@types/node": "^25.5.0",
    "@types/sinon": "^21.0.0",
    "@types/vec3": "^0.1.4",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "ava": "^7.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-ava": "^16.0.0",
    "globals": "^17.4.0",
    "sinon": "^21.0.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "overrides": {
    "axios": "^1.14.0"
  }
}
